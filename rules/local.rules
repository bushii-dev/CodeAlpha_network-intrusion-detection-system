# =========================================================
# Custom Suricata detection rules
# Place in /etc/suricata/rules/local.rules and reference it
# in suricata.yaml under rule-files.
# =========================================================

# --- Reconnaissance ---
alert icmp any any -> $HOME_NET any (msg:"Possible ICMP Ping Sweep"; itype:8; threshold:type both, track by_src, count 10, seconds 5; sid:1000001; rev:1;)

alert tcp any any -> $HOME_NET any (msg:"Possible Port Scan Detected"; flags:S; threshold:type both, track by_src, count 20, seconds 10; sid:1000003; rev:1;)

# --- Brute force ---
alert tcp any any -> $HOME_NET 22 (msg:"Possible SSH Brute Force"; flow:to_server; flags:S; threshold:type both, track by_src, count 5, seconds 60; sid:1000002; rev:1;)

alert tcp any any -> $HOME_NET 3389 (msg:"Possible RDP Brute Force"; flow:to_server; flags:S; threshold:type both, track by_src, count 5, seconds 60; sid:1000005; rev:1;)

# --- Web attack indicators ---
alert http any any -> $HOME_NET any (msg:"Suspicious User-Agent - sqlmap"; http.user_agent; content:"sqlmap"; nocase; sid:1000004; rev:1;)

alert http any any -> $HOME_NET any (msg:"Possible SQL Injection Attempt"; http.uri; content:"UNION SELECT"; nocase; sid:1000006; rev:1;)

alert http any any -> $HOME_NET any (msg:"Possible Directory Traversal Attempt"; http.uri; content:"../../"; sid:1000007; rev:1;)
